generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Trailer {
  id               String    @id
  movieTitle       String
  youtubeId        String    @unique
  releaseDate      String
  studio           String
  movieReleaseDate String?
  createdAt        DateTime  @default(now())
  boxOffice        BoxOffice?
}

model BoxOffice {
  id            String   @id @default(cuid())
  trailerId     String   @unique
  trailer       Trailer  @relation(fields: [trailerId], references: [id])
  day1India     Float?
  day1Worldwide Float?
  source        String
  sourceUrl     String?
  rawText       String?
  collectedAt   DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model StatsCache {
  youtubeId       String   @id
  views           Int
  likes           Int
  comments        Int
  likesPerView    Float
  commentsPerView Float
  title           String
  publishedAt     String
  thumbnailUrl    String
  refreshedAt     DateTime
}
